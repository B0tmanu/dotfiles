#!/bin/bash

export PATH="$HOME/.local/bin:$HOME/bin:$PATH"




# Directory containing wallpapers
WALL_DIR="$HOME/Pictures/walls"

# Current directory
CWD="$(pwd)"

cd "$WALL_DIR" || exit 1

# handle spaces in filenames
IFS=$'\n'

# grab the user-selected wallpaper
SELECTED_WALL=$(for a in *.jpg *.png; do echo -en "$a\0icon\x1f$a\n" ; done | rofi -dmenu -p "" -theme $HOME/.config/rofi/wallpaper-grid.rasi)

# if not empty pass to walset-backend
if [ -n "$SELECTED_WALL" ]; then
    walset-backend "$SELECTED_WALL"
fi

# go back where you came
cd "$CWD" || exit
