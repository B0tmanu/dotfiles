#!/bin/bash

# check if the user provided an argument
if [ "$#" -ne 1 ]; then
    echo "Usage: $0 <path_to_image>"
    exit 1
fi

IMAGE="$1"

# set wallpaper
awww img "$IMAGE" --transition-type="center" --transition-step=1 --transition-fps="165"

# send notification to the user
notify-send "Wallpaper vaihettu"

